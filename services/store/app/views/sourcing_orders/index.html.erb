<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Sourcing Orders</h1>
        <p class="text-sm text-gray-500 mt-1">Manage purchase orders and inventory sourcing</p>
      </div>
      
      <div class="flex gap-3">
        <%= link_to new_sourcing_order_path, 
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          New Order
        <% end %>
      </div>
    </div>
  </div>

  <!-- Status Tabs -->
  <div class="mb-6">
    <nav class="flex space-x-8">
      <%= link_to sourcing_orders_path, 
          class: "#{params[:status].blank? ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm" do %>
        All Orders
        <span class="ml-2 bg-gray-100 text-gray-900 hidden sm:inline-block py-0.5 px-2.5 rounded-full text-xs font-medium">
          <%= @sourcing_orders.count %>
        </span>
      <% end %>
      
      <%= link_to pending_sourcing_orders_path, 
          class: "#{params[:action] == 'pending' ? 'border-yellow-500 text-yellow-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm" do %>
        Pending
        <span class="ml-2 bg-yellow-100 text-yellow-900 hidden sm:inline-block py-0.5 px-2.5 rounded-full text-xs font-medium">
          <%= @pending_count %>
        </span>
      <% end %>
      
      <%= link_to approved_sourcing_orders_path, 
          class: "#{params[:action] == 'approved' ? 'border-green-500 text-green-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm" do %>
        Approved
        <span class="ml-2 bg-green-100 text-green-900 hidden sm:inline-block py-0.5 px-2.5 rounded-full text-xs font-medium">
          <%= @approved_count %>
        </span>
      <% end %>
      
      <%= link_to received_sourcing_orders_path, 
          class: "#{params[:action] == 'received' ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm" do %>
        Received
        <span class="ml-2 bg-blue-100 text-blue-900 hidden sm:inline-block py-0.5 px-2.5 rounded-full text-xs font-medium">
          <%= @received_count %>
        </span>
      <% end %>
    </nav>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow p-4">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-blue-100 rounded-md flex items-center justify-center">
            <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
            </svg>
          </div>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-gray-500">Draft Orders</p>
          <p class="text-lg font-semibold text-gray-900"><%= @pending_count %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-yellow-100 rounded-md flex items-center justify-center">
            <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L5.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
            </svg>
          </div>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-gray-500">Submitted</p>
          <p class="text-lg font-semibold text-gray-900"><%= @submitted_count %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-green-100 rounded-md flex items-center justify-center">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-gray-500">Approved</p>
          <p class="text-lg font-semibold text-gray-900"><%= @approved_count %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-purple-100 rounded-md flex items-center justify-center">
            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
          </div>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-gray-500">Received</p>
          <p class="text-lg font-semibold text-gray-900"><%= @received_count %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow mb-6">
    <%= form_with url: sourcing_orders_path, method: :get, local: true, class: "p-4" do |form| %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <%= form.select :status, 
              options_for_select([
                ['All Status', ''],
                ['Draft', 'draft'],
                ['Submitted', 'submitted'],
                ['Approved', 'approved'],
                ['Received', 'received'],
                ['Cancelled', 'cancelled']
              ], params[:status]),
              {}, { class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" } %>
        </div>
        
        <div>
          <%= form.select :supplier, 
              options_for_select([['All Suppliers', '']] + @suppliers.map { |s| [s, s] }, params[:supplier]),
              {}, { class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" } %>
        </div>
        
        <div class="flex gap-2">
          <%= form.submit 'Apply Filters', class: "flex-1 px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700" %>
          <%= link_to 'Clear', sourcing_orders_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Orders Table -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <% if @sourcing_orders.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Order</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Supplier</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Items</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total Cost</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @sourcing_orders.each do |order| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">
                  <%= link_to order.order_number.presence || "##{order.id}", order, class: "hover:text-blue-600" %>
                </div>
                <% if order.notes.present? %>
                  <div class="text-xs text-gray-500 truncate max-w-xs" title="<%= order.notes %>">
                    <%= truncate(order.notes, length: 30) %>
                  </div>
                <% end %>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900"><%= order.supplier_name %></div>
                <% if order.supplier_email.present? %>
                  <div class="text-xs text-gray-500"><%= order.supplier_email %></div>
                <% end %>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= order.sourcing_order_items.sum(:quantity) %> items
                <div class="text-xs text-gray-500">
                  <%= pluralize(order.sourcing_order_items.count, 'product') %>
                </div>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                ₲<%= number_with_delimiter(order.sourcing_order_items.sum { |item| (item.quantity || 0) * (item.unit_cost || 0) }.to_i) %>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= case order.status
                      when 'draft' then 'bg-gray-100 text-gray-800'
                      when 'submitted' then 'bg-yellow-100 text-yellow-800'
                      when 'approved' then 'bg-green-100 text-green-800'
                      when 'received' then 'bg-blue-100 text-blue-800'
                      when 'cancelled' then 'bg-red-100 text-red-800'
                      else 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= order.status.capitalize %>
                </span>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= order.order_date.strftime('%m/%d/%Y') if order.order_date %>
                <% if order.expected_delivery_date %>
                  <div class="text-xs text-gray-400">
                    Expected: <%= order.expected_delivery_date.strftime('%m/%d') %>
                  </div>
                <% end %>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <div class="flex gap-2">
                  <%= link_to 'View', order, class: "text-blue-600 hover:text-blue-900" %>
                  
                  <% case order.status %>
                  <% when 'draft' %>
                    <%= link_to 'Edit', edit_sourcing_order_path(order), class: "text-gray-600 hover:text-gray-900" %>
                    <%= link_to 'Submit', submit_sourcing_order_path(order), 
                        method: :patch, class: "text-green-600 hover:text-green-900" %>
                  <% when 'submitted' %>
                    <%= link_to 'Approve', approve_sourcing_order_path(order), 
                        method: :patch, class: "text-green-600 hover:text-green-900" %>
                  <% when 'approved' %>
                    <%= link_to 'Receive', receive_sourcing_order_path(order), 
                        method: :patch, class: "text-purple-600 hover:text-purple-900",
                        data: { confirm: 'Mark this order as received and update inventory?' } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <!-- Results Info -->
      <div class="px-6 py-4 border-t border-gray-200 text-sm text-gray-500">
        Showing <%= @sourcing_orders.count %> sourcing orders
      </div>

    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No sourcing orders found</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by creating your first purchase order.</p>
        <div class="mt-6">
          <%= link_to new_sourcing_order_path, 
              class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            New Sourcing Order
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>