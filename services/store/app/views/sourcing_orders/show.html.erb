<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <%= link_to sourcing_orders_path, class: "text-gray-400 hover:text-gray-600" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        <% end %>
        <div>
          <h1 class="text-2xl font-bold text-gray-900">
            Sourcing Order <%= @sourcing_order.order_number.presence || "##{@sourcing_order.id}" %>
          </h1>
          <p class="text-sm text-gray-500 mt-1">Purchase order details and status</p>
        </div>
      </div>
      
      <div class="flex gap-2">
        <% case @sourcing_order.status %>
        <% when 'draft' %>
          <%= link_to edit_sourcing_order_path(@sourcing_order), 
              class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Edit
          <% end %>
          
          <% if @items.any? %>
            <%= link_to submit_sourcing_order_path(@sourcing_order), method: :patch,
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700",
                data: { confirm: 'Submit this order for approval?' } do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
              </svg>
              Submit for Approval
            <% end %>
          <% end %>
          
        <% when 'submitted' %>
          <% if @can_approve %>
            <%= link_to approve_sourcing_order_path(@sourcing_order), method: :patch,
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700",
                data: { confirm: 'Approve this sourcing order?' } do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Approve Order
            <% end %>
          <% end %>
          
        <% when 'approved' %>
          <% if @can_receive %>
            <%= link_to receive_sourcing_order_path(@sourcing_order), method: :patch,
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700",
                data: { confirm: 'Mark this order as received and update inventory?' } do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
              </svg>
              Receive Order
            <% end %>
          <% end %>
        <% end %>
        
        <% if ['draft', 'submitted'].include?(@sourcing_order.status) %>
          <%= link_to cancel_sourcing_order_path(@sourcing_order), method: :patch,
              class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-red-600 bg-white hover:bg-red-50",
              data: { confirm: 'Cancel this sourcing order?' } do %>
            Cancel Order
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Order Status -->
      <div class="bg-white shadow rounded-lg p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-medium text-gray-900">Order Status</h3>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
            <%= case @sourcing_order.status
                when 'draft' then 'bg-gray-100 text-gray-800'
                when 'submitted' then 'bg-yellow-100 text-yellow-800'
                when 'approved' then 'bg-green-100 text-green-800'
                when 'received' then 'bg-blue-100 text-blue-800'
                when 'cancelled' then 'bg-red-100 text-red-800'
                end %>">
            <%= @sourcing_order.status.capitalize %>
          </span>
        </div>
        
        <div class="space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">Order Date:</span>
            <span class="text-gray-900">
              <%= @sourcing_order.order_date.strftime('%B %d, %Y') if @sourcing_order.order_date %>
            </span>
          </div>
          
          <% if @sourcing_order.submitted_date %>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Submitted:</span>
              <span class="text-gray-900">
                <%= @sourcing_order.submitted_date.strftime('%B %d, %Y') %>
              </span>
            </div>
          <% end %>
          
          <% if @sourcing_order.approved_date %>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Approved:</span>
              <span class="text-gray-900">
                <%= @sourcing_order.approved_date.strftime('%B %d, %Y') %>
              </span>
            </div>
          <% end %>
          
          <% if @sourcing_order.received_date %>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Received:</span>
              <span class="text-gray-900">
                <%= @sourcing_order.received_date.strftime('%B %d, %Y') %>
              </span>
            </div>
          <% end %>
          
          <% if @sourcing_order.expected_delivery_date %>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Expected Delivery:</span>
              <span class="text-gray-900 <%= @sourcing_order.expected_delivery_date < Date.current ? 'text-red-600' : '' %>">
                <%= @sourcing_order.expected_delivery_date.strftime('%B %d, %Y') %>
                <% if @sourcing_order.expected_delivery_date < Date.current && @sourcing_order.status != 'received' %>
                  <span class="text-red-600">(Overdue)</span>
                <% end %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Supplier Information -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Supplier Information</h3>
        </div>
        
        <div class="px-6 py-4">
          <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <dt class="text-sm font-medium text-gray-500">Company Name</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @sourcing_order.supplier_name %></dd>
            </div>
            
            <% if @sourcing_order.supplier_email.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Email</dt>
                <dd class="mt-1 text-sm text-gray-900">
                  <%= link_to @sourcing_order.supplier_email, "mailto:#{@sourcing_order.supplier_email}", class: "text-blue-600 hover:text-blue-800" %>
                </dd>
              </div>
            <% end %>
            
            <% if @sourcing_order.supplier_phone.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Phone</dt>
                <dd class="mt-1 text-sm text-gray-900">
                  <%= link_to @sourcing_order.supplier_phone, "tel:#{@sourcing_order.supplier_phone}", class: "text-blue-600 hover:text-blue-800" %>
                </dd>
              </div>
            <% end %>
            
            <% if @sourcing_order.order_number.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">PO Number</dt>
                <dd class="mt-1 text-sm text-gray-900 font-mono"><%= @sourcing_order.order_number %></dd>
              </div>
            <% end %>
          </dl>
          
          <% if @sourcing_order.supplier_address.present? %>
            <div class="mt-6">
              <dt class="text-sm font-medium text-gray-500">Address</dt>
              <dd class="mt-1 text-sm text-gray-900 whitespace-pre-line"><%= @sourcing_order.supplier_address %></dd>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Order Items -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Order Items</h3>
          <p class="mt-1 text-sm text-gray-500"><%= pluralize(@total_items, 'item') %> in this order</p>
        </div>
        
        <div class="overflow-hidden">
          <% if @items.any? %>
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Quantity</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Unit Cost</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @items.each do |item| %>
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center">
                        <% if item.product_variant.image.attached? %>
                          <%= image_tag item.product_variant.image, class: "w-10 h-10 object-cover rounded mr-3" %>
                        <% elsif item.product_variant.product.image.attached? %>
                          <%= image_tag item.product_variant.product.image, class: "w-10 h-10 object-cover rounded mr-3 opacity-50" %>
                        <% else %>
                          <div class="w-10 h-10 bg-gray-100 rounded mr-3 flex items-center justify-center">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                            </svg>
                          </div>
                        <% end %>
                        <div>
                          <div class="text-sm font-medium text-gray-900">
                            <%= link_to item.product_variant.product.name, item.product_variant.product, class: "hover:text-blue-600" %>
                          </div>
                          <div class="text-sm text-gray-500">SKU: <%= item.product_variant.sku %></div>
                          <% if item.notes.present? %>
                            <div class="text-xs text-gray-400"><%= item.notes %></div>
                          <% end %>
                        </div>
                      </div>
                    </td>
                    
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                      <%= item.quantity %> units
                    </td>
                    
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                      ₲<%= number_with_delimiter(item.unit_cost) if item.unit_cost %>
                    </td>
                    
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                      ₲<%= number_with_delimiter((item.quantity || 0) * (item.unit_cost || 0)) %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
              <tfoot class="bg-gray-50">
                <tr>
                  <td colspan="3" class="px-6 py-4 text-right text-sm font-medium text-gray-900">
                    Total Order Value:
                  </td>
                  <td class="px-6 py-4 text-sm font-bold text-gray-900">
                    ₲<%= number_with_delimiter(@total_cost.to_i) %>
                  </td>
                </tr>
              </tfoot>
            </table>
          <% else %>
            <div class="text-center py-6">
              <p class="text-gray-500">No items added to this order yet.</p>
              <% if @sourcing_order.status == 'draft' %>
                <%= link_to 'Add Items', edit_sourcing_order_path(@sourcing_order), 
                    class: "mt-2 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Notes -->
      <% if @sourcing_order.notes.present? %>
        <div class="bg-white shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">Order Notes</h3>
          </div>
          
          <div class="px-6 py-4">
            <div class="text-sm text-gray-900 whitespace-pre-line"><%= @sourcing_order.notes %></div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Order Summary -->
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Order Summary</h3>
        
        <div class="space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">Total Items:</span>
            <span class="text-gray-900 font-medium"><%= @total_items %></span>
          </div>
          
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">Product Lines:</span>
            <span class="text-gray-900 font-medium"><%= @items.count %></span>
          </div>
          
          <div class="flex justify-between text-sm border-t border-gray-200 pt-3">
            <span class="text-gray-500">Total Cost:</span>
            <span class="text-gray-900 font-bold">₲<%= number_with_delimiter(@total_cost.to_i) %></span>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Quick Actions</h3>
        
        <div class="space-y-3">
          <%= link_to sourcing_orders_path, 
              class: "w-full flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
            </svg>
            All Orders
          <% end %>
          
          <%= link_to new_sourcing_order_path, 
              class: "w-full flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            New Order
          <% end %>
          
          <% if @sourcing_order.status == 'received' %>
            <%= link_to inventory_adjustments_path(type: 'purchase'), 
                class: "w-full flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
              <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
              </svg>
              View Adjustments
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Workflow Guide -->
      <% unless @sourcing_order.status == 'received' %>
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
          <h4 class="text-sm font-medium text-blue-900 mb-2">Next Steps</h4>
          <div class="text-sm text-blue-700">
            <% case @sourcing_order.status %>
            <% when 'draft' %>
              <p>1. Add items to the order</p>
              <p>2. Submit for approval</p>
              <p>3. Wait for approval</p>
              <p>4. Receive inventory</p>
            <% when 'submitted' %>
              <p>1. ✅ Order submitted</p>
              <p>2. ⏳ Waiting for approval</p>
              <p>3. Receive inventory</p>
            <% when 'approved' %>
              <p>1. ✅ Order approved</p>
              <p>2. ⏳ Receive inventory when delivered</p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>