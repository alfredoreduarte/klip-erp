<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center gap-3">
      <%= link_to sourcing_orders_path, class: "text-gray-400 hover:text-gray-600" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      <% end %>
      <div>
        <h1 class="text-2xl font-bold text-gray-900">New Sourcing Order</h1>
        <p class="text-sm text-gray-500 mt-1">Create a purchase order for inventory replenishment</p>
      </div>
    </div>
  </div>

  <!-- Low Stock Alert -->
  <% if @low_stock_variants.any? %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-yellow-800">
            <%= pluralize(@low_stock_variants.count, 'product') %> running low on stock
          </h3>
          <div class="mt-2 text-sm text-yellow-700">
            <p>Consider adding these items to your order:</p>
            <div class="mt-2 max-h-20 overflow-y-auto">
              <% @low_stock_variants.first(5).each do |variant| %>
                <div class="text-xs">
                  • <%= variant.product.name %> (<%= variant.sku %>) - <%= variant.inventory_quantity %> left
                </div>
              <% end %>
              <% if @low_stock_variants.count > 5 %>
                <div class="text-xs text-yellow-600 mt-1">
                  ... and <%= @low_stock_variants.count - 5 %> more
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Form -->
  <%= form_with model: @sourcing_order, local: true, class: "space-y-6" do |form| %>
    <% if @sourcing_order.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @sourcing_order.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Supplier Information -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200">
        <h3 class="text-lg font-medium text-gray-900">Supplier Information</h3>
        <p class="mt-1 text-sm text-gray-500">Provide supplier details for this purchase order.</p>
      </div>
      
      <div class="px-6 py-4 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :supplier_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :supplier_name, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "Supplier company name",
                required: true %>
          </div>
          
          <div>
            <%= form.label :supplier_email, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.email_field :supplier_email, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "supplier@company.com" %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :supplier_phone, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.tel_field :supplier_phone, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "Phone number" %>
          </div>
          
          <div>
            <%= form.label :order_number, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.text_field :order_number, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "Optional: Purchase order number" %>
          </div>
        </div>

        <div>
          <%= form.label :supplier_address, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_area :supplier_address, rows: 2,
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "Supplier address" %>
        </div>

        <div>
          <%= form.label :expected_delivery_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.date_field :expected_delivery_date, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
              min: Date.current.strftime('%Y-%m-%d') %>
        </div>
      </div>
    </div>

    <!-- Order Items -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-medium text-gray-900">Order Items</h3>
            <p class="mt-1 text-sm text-gray-500">Add products to this purchase order.</p>
          </div>
          <button type="button" id="add-item-btn" 
                  class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-blue-600 bg-blue-100 hover:bg-blue-200">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Add Item
          </button>
        </div>
      </div>
      
      <div class="px-6 py-4">
        <div id="order-items">
          <%= form.fields_for :sourcing_order_items do |item_form| %>
            <div class="border border-gray-200 rounded-lg p-4 mb-4 order-item">
              <div class="flex justify-between items-start mb-4">
                <h4 class="text-sm font-medium text-gray-900">Item</h4>
                <button type="button" class="remove-item text-red-600 hover:text-red-800">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                </button>
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="md:col-span-2">
                  <%= item_form.label :product_variant_id, "Product Variant", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= item_form.select :product_variant_id, 
                      options_from_collection_for_select(@products.flat_map(&:product_variants), :id, 
                        ->(variant) { "#{variant.product.name} - #{variant.sku} (Stock: #{variant.inventory_quantity})" }),
                      { prompt: "Select product variant..." },
                      { class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" } %>
                </div>
                
                <div>
                  <%= item_form.label :quantity, class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= item_form.number_field :quantity, min: 1,
                      class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                      placeholder: "Qty" %>
                </div>
                
                <div>
                  <%= item_form.label :unit_cost, class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                      <span class="text-gray-500 sm:text-sm">₲</span>
                    </div>
                    <%= item_form.number_field :unit_cost, step: 0.01, min: 0,
                        class: "w-full pl-7 pr-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                        placeholder: "0.00" %>
                  </div>
                </div>
              </div>
              
              <div class="mt-4">
                <%= item_form.label :notes, "Item Notes", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= item_form.text_area :notes, rows: 2,
                    class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                    placeholder: "Optional notes for this item..." %>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Add item template (hidden) -->
        <div id="item-template" class="hidden">
          <div class="border border-gray-200 rounded-lg p-4 mb-4 order-item">
            <div class="flex justify-between items-start mb-4">
              <h4 class="text-sm font-medium text-gray-900">Item</h4>
              <button type="button" class="remove-item text-red-600 hover:text-red-800">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
              </button>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Product Variant</label>
                <select name="sourcing_order[sourcing_order_items_attributes][INDEX][product_variant_id]" 
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500">
                  <option value="">Select product variant...</option>
                  <% @products.each do |product| %>
                    <optgroup label="<%= product.name %>">
                      <% product.product_variants.each do |variant| %>
                        <option value="<%= variant.id %>">
                          <%= variant.sku %> - <%= variant.name.presence || "Default" %> (Stock: <%= variant.inventory_quantity %>)
                        </option>
                      <% end %>
                    </optgroup>
                  <% end %>
                </select>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                <input type="number" name="sourcing_order[sourcing_order_items_attributes][INDEX][quantity]" min="1"
                       class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="Qty">
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Unit Cost</label>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <span class="text-gray-500 sm:text-sm">₲</span>
                  </div>
                  <input type="number" name="sourcing_order[sourcing_order_items_attributes][INDEX][unit_cost]" step="0.01" min="0"
                         class="w-full pl-7 pr-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
                         placeholder="0.00">
                </div>
              </div>
            </div>
            
            <div class="mt-4">
              <label class="block text-sm font-medium text-gray-700 mb-1">Item Notes</label>
              <textarea name="sourcing_order[sourcing_order_items_attributes][INDEX][notes]" rows="2"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
                        placeholder="Optional notes for this item..."></textarea>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Additional Information -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200">
        <h3 class="text-lg font-medium text-gray-900">Additional Information</h3>
        <p class="mt-1 text-sm text-gray-500">Optional notes and special instructions.</p>
      </div>
      
      <div class="px-6 py-4">
        <%= form.label :notes, "Order Notes", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :notes, rows: 4,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
            placeholder: "Special instructions, terms, or notes for this order..." %>
      </div>
    </div>

    <!-- Form Actions -->
    <div class="flex justify-end gap-3 pt-6 border-t border-gray-200">
      <%= link_to 'Cancel', sourcing_orders_path, 
          class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
      <%= form.submit 'Create Draft Order',
          class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700" %>
    </div>
  <% end %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const addItemBtn = document.getElementById('add-item-btn');
  const orderItems = document.getElementById('order-items');
  const itemTemplate = document.getElementById('item-template');
  let itemIndex = <%= @sourcing_order.sourcing_order_items.size %>;

  // Add item functionality
  addItemBtn.addEventListener('click', function() {
    const newItem = itemTemplate.innerHTML.replace(/INDEX/g, itemIndex);
    const itemDiv = document.createElement('div');
    itemDiv.innerHTML = newItem;
    orderItems.appendChild(itemDiv.firstElementChild);
    itemIndex++;
  });

  // Remove item functionality
  orderItems.addEventListener('click', function(e) {
    if (e.target.closest('.remove-item')) {
      const item = e.target.closest('.order-item');
      if (orderItems.children.length > 1) {
        item.remove();
      } else {
        alert('At least one item is required for the order.');
      }
    }
  });

  // Add first item if none exist
  if (orderItems.children.length === 0) {
    addItemBtn.click();
  }
});
</script>