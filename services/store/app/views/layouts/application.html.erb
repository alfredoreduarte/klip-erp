<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Store" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>

  <body>
    <nav class="bg-white shadow-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <%= link_to "Store Admin", root_path, class: "text-xl font-bold text-gray-800" %>
            </div>
            <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
              <%= link_to "Home", root_path, class: "text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium" %>
              <%= link_to "Pedidos", orders_path, class: "text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium" %>
              <%= link_to "Chats", chats_path, class: "text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium" %>
              
              <!-- Products Dropdown -->
              <div class="relative" x-data="{ open: false }">
                <button @click="open = !open" class="text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium focus:outline-none">
                  Productos
                  <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div x-show="open" @click.away="open = false" 
                     class="absolute z-10 mt-2 w-48 bg-white rounded-md shadow-lg py-1 ring-1 ring-black ring-opacity-5">
                  <%= link_to products_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    📦 Product Catalog
                  <% end %>
                  <%= link_to low_stock_products_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    ⚠️ Low Stock Alert
                  <% end %>
                  <%= link_to new_product_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    ➕ Add Product
                  <% end %>
                </div>
              </div>
              
              <!-- Inventory Dropdown -->
              <div class="relative" x-data="{ open: false }">
                <button @click="open = !open" class="text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium focus:outline-none">
                  Inventario
                  <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div x-show="open" @click.away="open = false" 
                     class="absolute z-10 mt-2 w-48 bg-white rounded-md shadow-lg py-1 ring-1 ring-black ring-opacity-5">
                  <%= link_to inventory_adjustments_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    📝 Adjustments
                  <% end %>
                  <%= link_to inventory_lots_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    📦 Inventory Lots
                  <% end %>
                  <%= link_to new_inventory_adjustment_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    ➕ Adjust Stock
                  <% end %>
                  <%= link_to expiring_inventory_lots_path, class: "block px-4 py-2 text-sm text-orange-700 hover:bg-orange-50" do %>
                    ⏰ Expiring Soon
                  <% end %>
                </div>
              </div>
              
              <!-- Sourcing Dropdown -->
              <div class="relative" x-data="{ open: false }">
                <button @click="open = !open" class="text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium focus:outline-none">
                  Compras
                  <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div x-show="open" @click.away="open = false" 
                     class="absolute z-10 mt-2 w-48 bg-white rounded-md shadow-lg py-1 ring-1 ring-black ring-opacity-5">
                  <%= link_to sourcing_orders_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    🛒 Purchase Orders
                  <% end %>
                  <%= link_to pending_sourcing_orders_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    ⏳ Pending Orders
                  <% end %>
                  <%= link_to new_sourcing_order_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    ➕ New Order
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="flex items-center">
            <%= link_to "Nuevo Pedido", new_order_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium" %>
          </div>
        </div>
      </div>
    </nav>
    
    <%= yield %>
  </body>
</html>
