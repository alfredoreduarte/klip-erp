<div class="whatsapp-chat-container">
  <div class="flex h-screen bg-gray-50">
    <!-- Left-most vertical sidebar for WAHA sessions & other sections -->
    <aside class="session-sidebar">
      <div class="space-y-3 w-full px-2">
        <% @sessions.each do |session| %>
          <% active_session = defined?(@waha_session) && @waha_session&.id == session.id %>
          <%= link_to waha_session_chats_path(session), class: "session-item #{'active' if active_session}", title: session.display_name do %>
            <% if session.profile_pic_url.present? %>
              <img src="<%= session.profile_pic_url %>" alt="session avatar" class="w-full h-full object-cover rounded-full" />
            <% else %>
              <span class="session-item-text"><%= session.name.first(2) %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <div class="px-2">
        <button onclick="openNewSessionModal()" class="create-session-btn" title="Create New Session">
          +
        </button>
      </div>
    </aside>

    <!-- Middle column – chat list -->
    <section class="w-[370px] bg-white border-r border-gray-300 flex flex-col">
      <!-- Header -->
      <div class="whatsapp-header">
        <div class="flex items-center justify-between w-full">
          <h1 class="text-xl font-medium text-[#111b21]">Chats</h1>
          <div class="whatsapp-header-actions">
            <button class="whatsapp-action-btn" title="New chat">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z"/>
              </svg>
            </button>
            <button class="whatsapp-action-btn" title="Menu">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Search box -->
      <div class="search-container">
        <div class="search-wrapper">
          <span class="search-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 103.5 10.5a7.5 7.5 0 0013.15 6.15z" />
            </svg>
          </span>
          <input type="text" placeholder="Search or start new chat" class="search-input" disabled>
        </div>
      </div>

      <!-- Chat list -->
      <div id="chats_list" data-controller="chat-list" class="overflow-y-auto flex-1">
        <%= turbo_stream_from "chats" %>
        <%= render partial: "chats/chat_list_item", collection: @chats, as: :chat %>
      </div>
    </section>

    <!-- Right column – active chat -->
    <section class="flex-1 flex flex-col chat-bg">
      <!-- Chat header -->
      <div class="whatsapp-header">
        <div class="flex items-center flex-1">
          <div class="whatsapp-header-avatar overflow-hidden">
            <% if @chat.profile_pic_url.present? %>
              <img src="<%= @chat.profile_pic_url %>" alt="avatar" class="w-full h-full object-cover rounded-full" />
            <% else %>
              <% initials = (@chat.name.presence || @chat.wa_id).split(/\s/).map { _1.first }.join.upcase[0,2] %>
              <%= initials %>
            <% end %>
          </div>
          <div class="whatsapp-header-info">
            <h2 class="whatsapp-header-name"><%= @chat.name.presence || @chat.wa_id %></h2>
            <p class="whatsapp-header-status">last seen recently</p>
          </div>
        </div>
        <div class="whatsapp-header-actions">
          <button class="whatsapp-action-btn" title="Search">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
            </svg>
          </button>
          <%= button_to sync_pin_states_chat_path(@chat), method: :post, class: "whatsapp-action-btn", title: "Sync pin states" do %>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/>
            </svg>
          <% end %>
          <button class="whatsapp-action-btn" title="Attach">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8 4a3 3 0 00-3 3v4a5 5 0 0010 0V7a1 1 0 112 0v4a7 7 0 11-14 0V7a5 5 0 0110 0v4a3 3 0 11-6 0V7a1 1 0 012 0v4a1 1 0 102 0V7a3 3 0 00-3-3z" clip-rule="evenodd"/>
            </svg>
          </button>
          <button class="whatsapp-action-btn" title="Menu">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Messages scroller -->
      <turbo-frame id="chat_<%= @chat.id %>_messages" class="flex-1 overflow-y-auto p-6" target="_top">
        <%# Subscribe to message and presence updates for this chat %>
        <%= turbo_stream_from @chat %>
        <%= turbo_stream_from "chat_presence_#{@chat.id}" %>
        <div id="messages_scroller" class="space-y-2">
          <!-- Pinned Messages Section -->
          <% if @chat.pinned_messages.any? %>
            <div class="pinned-messages-section mb-4 p-3 bg-yellow-50 border border-yellow-200 rounded-lg">
              <div class="flex items-center mb-2">
                <svg class="w-4 h-4 text-yellow-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span class="text-sm font-medium text-yellow-800">Pinned Messages</span>
              </div>
              <div class="space-y-2">
                <% @chat.pinned_messages.limit(3).each do |pinned_message| %>
                  <div class="pinned-message-preview p-2 bg-white rounded border border-yellow-300">
                    <div class="flex items-center justify-between">
                      <div class="flex-1 min-w-0">
                        <div class="text-xs text-gray-500 mb-1">
                          <%= pinned_message.outgoing? ? 'You' : (@chat.name || 'Contact') %> • <%= pinned_message.created_at.strftime('%H:%M') %>
                        </div>
                        <div class="text-sm text-gray-700 truncate">
                          <% case pinned_message.message_type %>
                          <% when 'text' %>
                            <%= pinned_message.body %>
                          <% when 'image' %>
                            📷 Image
                          <% when 'video' %>
                            🎥 Video
                          <% when 'audio', 'ptt' %>
                            🎵 Voice message
                          <% when 'document' %>
                            📄 Document
                          <% when 'location' %>
                            📍 Location
                          <% when 'contact' %>
                            👤 Contact
                          <% else %>
                            <%= pinned_message.message_type&.titleize %>
                          <% end %>
                        </div>
                      </div>
                      <%= button_to unpin_chat_message_path(@chat, pinned_message), method: :patch, class: "ml-2 p-1 text-yellow-600 hover:text-yellow-800 hover:bg-yellow-100 rounded transition-colors", title: "Unpin message" do %>
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"/>
                        </svg>
                      <% end %>
                    </div>
                  </div>
                <% end %>
                <% if @chat.pinned_messages.count > 3 %>
                  <div class="text-xs text-yellow-600 text-center">
                    +<%= @chat.pinned_messages.count - 3 %> more pinned messages
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <% grouped_messages = @messages.group_by { |m| (m.sent_at || m.created_at).to_date } %>
          <% grouped_messages.each do |date, msgs| %>
            <%= render partial: "messages/date_separator", locals: { date: date } %>
            <%= render partial: "messages/message", collection: msgs, as: :message %>
          <% end %>

          <!-- Typing indicator -->
          <%= render partial: "chats/typing_indicator", locals: { chat: @chat, show: false } %>
        </div>
      </turbo-frame>

      <!-- Message composer -->
      <div class="message-composer">
        <%= form_with model: [@chat, Message.new], data: { turbo_stream: true }, class: "composer-form" do |f| %>
          <!-- Attachment button -->
          <button type="button" class="composer-attachment-btn" title="Attach file">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8 4a3 3 0 00-3 3v4a5 5 0 0010 0V7a1 1 0 112 0v4a7 7 0 11-14 0V7a5 5 0 0110 0v4a3 3 0 11-6 0V7a1 1 0 012 0v4a1 1 0 102 0V7a3 3 0 00-3-3z" clip-rule="evenodd"/>
            </svg>
          </button>

          <!-- Message input -->
          <div class="composer-input-wrapper">
            <%= f.text_field :body, class: "composer-input", placeholder: "Type a message", rows: 1, data: { controller: "typing", "typing-chat-id-value": @chat.id, action: "input->typing#start blur->typing#stop" } %>
          </div>

          <!-- Send button -->
          <%= f.submit class: "composer-send-btn" do %>
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/>
            </svg>
          <% end %>
        <% end %>
      </div>
    </section>
  </div>

  <!-- New Session Modal -->
  <%= render partial: "chats/new_session_modal" %>
</div>

<%= auto_scroll_frame %>