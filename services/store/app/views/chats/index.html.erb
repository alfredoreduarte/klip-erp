<!-- WhatsApp-like chat interface -->
<div class="whatsapp-chat-container h-screen flex flex-col">
  <!-- Header -->
  <div class="whatsapp-header">
    <div class="whatsapp-header-avatar">
      <% if defined?(@waha_session) && @waha_session.present? %>
        <%= @waha_session.name.first.upcase %>
      <% else %>
        C
      <% end %>
    </div>
    <div class="whatsapp-header-info">
      <div class="whatsapp-header-name">
        <% if defined?(@waha_session) && @waha_session.present? %>
          <%= @waha_session.name %> - Chats
        <% else %>
          All Chats
        <% end %>
      </div>
      <div class="whatsapp-header-status">
        <%= pluralize(@chats.size, 'chat') %> total
        <% if defined?(@waha_session) && @waha_session.present? %>
          | <%= link_to "Back to sessions", waha_sessions_path, class: "text-[#00a884] hover:underline" %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Chat List -->
  <div class="flex-1 overflow-y-auto bg-white">
    <% if @chats.any? %>
      <% @chats.each do |chat| %>
        <%= render 'chat_list_item', chat: chat %>
      <% end %>
    <% else %>
      <div class="flex items-center justify-center h-full text-[#667781]">
        <div class="text-center">
          <div class="text-6xl mb-4">💬</div>
          <h3 class="text-lg font-medium mb-2">No chats yet</h3>
          <p class="text-sm">Wait for WhatsApp messages or start a conversation</p>
        </div>
      </div>
    <% end %>
  </div>
</div>