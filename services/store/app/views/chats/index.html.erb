<h1 class="text-xl font-bold mb-4">
  Chats
  <% if defined?(@waha_session) && @waha_session.present? %>
    for session <span class="font-semibold"><%= @waha_session.name %></span>
    (<%= link_to "Back to sessions", waha_sessions_path, class: "text-blue-600 underline" %>)
  <% end %>
</h1>

<ul class="space-y-2">
  <% @chats.each do |chat| %>
    <li>
      <%= link_to chat_path(chat), class: "text-blue-600 hover:underline" do %>
        <%= chat.name.presence || chat.wa_id %>
        <% if chat.last_message_at.present? %>
          <span class="text-xs text-gray-500 ml-2"><%= time_ago_in_words(chat.last_message_at) %> ago</span>
        <% end %>
      <% end %>
    </li>
  <% end %>
</ul>

<% if @chats.empty? %>
  <p>No chats yet. Wait for WhatsApp traffic or send a message first.</p>
<% end %>