<%# frozen_string_literal: true %>
<% active = defined?(@chat) && @chat.id == chat.id %>
<%= link_to chat_path(chat), class: "group flex items-center px-4 py-3 hover:bg-[#f5f6f6] cursor-pointer #{'bg-[#e9edef]' if active}" do %>
  <div class="flex-shrink-0">
    <% initials = (chat.name.presence || chat.wa_id).split(/\s/).map { _1.first }.join.upcase[0,2] %>
    <div class="w-12 h-12 rounded-full bg-[#6b7c85] text-white flex items-center justify-center text-base font-medium">
      <%= initials %>
    </div>
  </div>
  <div class="ml-4 flex-1 min-w-0">
    <div class="flex justify-between items-start">
      <p class="font-normal text-[#111b21] truncate"><%= chat.name.presence || chat.wa_id %></p>
      <% if chat.last_message_at.present? %>
        <p class="text-xs text-[#667781] whitespace-nowrap ml-2"><%= chat.last_message_at.strftime('%H:%M') %></p>
      <% end %>
    </div>
    <% if chat.messages.last&.body.present? %>
      <p class="text-sm text-[#667781] truncate mt-0.5"><%= truncate(chat.messages.last.body.to_s, length: 50) %></p>
    <% end %>
  </div>
<% end %>