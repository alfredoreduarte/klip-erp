<%# frozen_string_literal: true %>
<% active = defined?(@chat) && @chat.id == chat.id %>
<%# Fetch the newest message via model helper to keep view slim %>
<% last_message = chat.latest_message %>
<%= link_to chat_path(chat), id: dom_id(chat, :list_item), class: "group chat-list-item #{'active' if active}", data: { turbo_prefetch: false, "chat-list-target": "item" } do %>
  <div class="chat-avatar overflow-hidden">
    <% if chat.profile_pic_url.present? %>
      <img src="<%= chat.profile_pic_url %>" alt="avatar" class="w-full h-full object-cover rounded-full" />
    <% else %>
      <% initials = (chat.name.presence || chat.wa_id).split(/\s/).map { _1.first }.join.upcase[0,2] %>
      <%= initials %>
    <% end %>
  </div>

  <div class="chat-info">
    <div class="chat-header">
      <h3 class="chat-name"><%= chat.name.presence || chat.wa_id %></h3>
      <div class="flex flex-col items-end ml-auto min-w-[48px]">
        <% timestamp = chat.latest_message_timestamp %>
        <% if timestamp.present? %>
          <span class="chat-time text-xs text-[#8696a0] mb-1"><%= whatsapp_chat_timestamp(timestamp) %></span>
        <% end %>
        <% if chat.messages.incoming.where(read_at: nil).exists? %>
          <div class="chat-unread-badge">
            <%= chat.messages.incoming.where(read_at: nil).count %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-between">
      <div class="flex items-center flex-1 min-w-0">
        <%# We already fetched last_message at the top %>
        <% is_location = last_message && (last_message.message_type == 'location' || (last_message.message_type == 'text' && (last_message.payload['location'].present? || (last_message.payload['lat'].present? && last_message.payload['lng'].present?)))) %>
        <% if is_location %>
          <div class="flex items-center text-[#667781]">
            <% if last_message.outgoing? %>
              <%
                age_minutes = (Time.current - last_message.created_at) / 1.minute
                if age_minutes < 5
                  status_class = "text-[#667781]"
                elsif age_minutes < 30
                  status_class = "text-[#667781]"
                else
                  status_class = "text-[#53bdeb]"
                end
              %>
              <svg class="w-3 h-3 mr-1 <%= status_class %>" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            <% end %>
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C8.134 2 5 5.134 5 9c0 4.545 5.4 9.318 6.165 10.047.426.406 1.244.406 1.67 0C13.6 18.318 19 13.545 19 9c0-3.866-3.134-7-7-7zM12 11.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" clip-rule="evenodd"/>
            </svg>
            <span class="chat-preview">Location</span>
          </div>
        <% elsif last_message&.body.present? %>
          <% if last_message.outgoing? %>
            <div class="flex items-center mr-1">
              <!-- Status indicator for outgoing messages -->
              <%
                age_minutes = (Time.current - last_message.created_at) / 1.minute
                if age_minutes < 5
                  status_class = "text-[#667781]"
                elsif age_minutes < 30
                  status_class = "text-[#667781]"
                else
                  status_class = "text-[#53bdeb]"
                end
              %>
              <svg class="w-3 h-3 <%= status_class %>" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            </div>
          <% end %>
          <p class="chat-preview"><%= truncate(last_message.body.to_s, length: 50) %></p>
        <% elsif last_message&.message_type == 'image' || (last_message&.message_type == 'text' && last_message&.payload&.dig('hasMedia') == true && last_message&.payload&.dig('mediaUrl')&.include?('.jpeg')) %>
          <div class="flex items-center text-[#667781]">
            <% if last_message.outgoing? %>
              <svg class="w-3 h-3 mr-1 text-[#667781]" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            <% end %>
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
            </svg>
            <span class="chat-preview">Photo</span>
          </div>
        <% elsif last_message&.message_type == 'text' && last_message&.payload&.dig('hasMedia') == true && last_message&.payload&.dig('mediaUrl')&.include?('.oga') %>
          <div class="flex items-center text-[#667781]">
            <% if last_message.outgoing? %>
              <svg class="w-3 h-3 mr-1 text-[#667781]" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            <% end %>
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M9.383 3.076A1 1 0 0110 4v12a1 1 0 01-1.617.793L4.5 13H2a1 1 0 01-1-1V8a1 1 0 011-1h2.5l3.883-3.793a1 1 0 011.617.793zM12.293 7.293a1 1 0 011.414 0L15 8.586l1.293-1.293a1 1 0 111.414 1.414L16.414 10l1.293 1.293a1 1 0 01-1.414 1.414L15 11.414l-1.293 1.293a1 1 0 01-1.414-1.414L13.586 10l-1.293-1.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
            <span class="chat-preview">Voice message</span>
          </div>
        <% elsif last_message&.message_type == 'text' && last_message&.payload&.dig('hasMedia') == true %>
          <div class="flex items-center text-[#667781]">
            <% if last_message.outgoing? %>
              <svg class="w-3 h-3 mr-1 text-[#667781]" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            <% end %>
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
            </svg>
            <span class="chat-preview">Media</span>
          </div>
        <% elsif last_message&.message_type == 'video' %>
          <div class="flex items-center text-[#667781]">
            <% if last_message.outgoing? %>
              <svg class="w-3 h-3 mr-1 text-[#667781]" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            <% end %>
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm2 0h12v10H4V5zm6 3a1 1 0 00-1.447.894l4 2A1 1 0 0014 10l-4-2z" clip-rule="evenodd"/>
            </svg>
            <span class="chat-preview">Video</span>
          </div>
        <% elsif last_message&.message_type == 'notification_template' || last_message&.payload&.dig('_data', 'subtype') == 'contact_info_card' %>
          <div class="flex items-center text-[#667781]">
            <% if last_message.outgoing? %>
              <svg class="w-3 h-3 mr-1 text-[#667781]" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            <% end %>
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <% if last_message.payload.dig('_data', 'subtype') == 'contact_info_card' %>
              <span class="chat-preview">Contact info</span>
            <% else %>
              <span class="chat-preview">Notification</span>
            <% end %>
          </div>
        <% elsif last_message&.message_type == 'document' %>
          <div class="flex items-center text-[#667781]">
            <% if last_message.outgoing? %>
              <svg class="w-3 h-3 mr-1 text-[#667781]" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            <% end %>
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2H4zm0 2h12v8H4V6zm2 1a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm0 3a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1z" clip-rule="evenodd"/>
            </svg>
            <span class="chat-preview">Document</span>
          </div>
        <% elsif last_message&.message_type == 'audio' %>
          <div class="flex items-center text-[#667781]">
            <% if last_message.outgoing? %>
              <svg class="w-3 h-3 mr-1 text-[#667781]" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            <% end %>
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M9.383 3.076A1 1 0 0110 4v12a1 1 0 01-1.617.793L4.5 13H2a1 1 0 01-1-1V8a1 1 0 011-1h2.5l3.883-3.793a1 1 0 011.617.793zM12.293 7.293a1 1 0 011.414 0L15 8.586l1.293-1.293a1 1 0 111.414 1.414L16.414 10l1.293 1.293a1 1 0 01-1.414 1.414L15 11.414l-1.293 1.293a1 1 0 01-1.414-1.414L13.586 10l-1.293-1.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
            <span class="chat-preview">Voice message</span>
          </div>
        <% elsif last_message&.message_type == 'sticker' %>
          <div class="flex items-center text-[#667781]">
            <% if last_message.outgoing? %>
              <svg class="w-3 h-3 mr-1 text-[#667781]" viewBox="0 0 16 15">
                <path fill="currentColor" d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.063-.51zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l3.61 3.463c.143.14.361.125.484-.033L10.91 3.879a.366.366 0 0 0-.063-.51z"/>
              </svg>
            <% end %>
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM7 9a1 1 0 100-2 1 1 0 000 2zm7-1a1 1 0 11-2 0 1 1 0 012 0zm-7.536 5.879a1 1 0 001.415 0 3 3 0 014.242 0 1 1 0 001.415-1.415 5 5 0 00-7.072 0 1 1 0 000 1.415z" clip-rule="evenodd"/>
            </svg>
            <span class="chat-preview">Sticker</span>
          </div>
        <% else %>
          <p class="chat-preview text-[#8696a0]">No messages yet</p>
        <% end %>
      </div>
    </div>
  </div>
<% end %>