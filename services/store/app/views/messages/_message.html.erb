              </svg>
            <% end %>
          </span>
        <% end %>
      </div>
    <% when 'video' %>
      <div class="bubble-content">
        <% url = message.payload['url'] || message.payload['media_url'] %>
        <%= video_tag url, controls: true, class: 'rounded max-w-full h-60 block' if url.present? %>
        <% if message.body.present? %>
