              </svg>
            <% end %>
          </span>
        <% end %>
      </div>
    <% when 'location' %>
      <div class="bubble-content">
        <% loc = message.payload['location'] || {} %>
        <% lat = loc['latitude'] || loc['lat'] %>
        <% lng = loc['longitude'] || loc['lng'] %>
