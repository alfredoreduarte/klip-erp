<div class="min-h-screen bg-gray-50 py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8 flex justify-between items-center">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Pedidos</h1>
        <p class="text-gray-600 mt-1">Gestión de pedidos del sistema</p>
      </div>
      <%= link_to "Nuevo Pedido", new_order_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition duration-200" %>
    </div>

    <!-- Orders Table -->
    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <ul class="divide-y divide-gray-200">
        <% if @orders.any? %>
          <% @orders.each do |order| %>
            <li>
              <div class="px-4 py-4 sm:px-6 hover:bg-gray-50">
                <div class="flex items-center justify-between">
                  <div class="flex items-center">
                    <div class="flex-shrink-0">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                        <%= order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                            order.status == 'confirmed' ? 'bg-blue-100 text-blue-800' :
                            order.status == 'delivered' ? 'bg-green-100 text-green-800' :
                            'bg-gray-100 text-gray-800' %>">
                        <%= order.status.humanize %>
                      </span>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900">
                        <%= link_to order.order_number, order_path(order), class: "hover:text-blue-600" %>
                      </div>
                      <div class="text-sm text-gray-500">
                        <%= order.customer_name %> <%= order.customer_surname %>
                        <% if order.customer_phone.present? %>
                          • <%= order.customer_phone %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  <div class="flex items-center">
                    <div class="text-right mr-4">
                      <div class="text-sm font-medium text-gray-900">
                        ₲<%= order.total_amount.to_i.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\\1.').reverse %>
                      </div>
                      <div class="text-sm text-gray-500">
                        <%= order.total_items %> items
                      </div>
                    </div>
                    <div class="text-right">
                      <div class="text-sm text-gray-900">
                        <%= order.created_at.strftime("%d/%m/%Y") %>
                      </div>
                      <div class="text-sm text-gray-500">
                        <%= order.created_at.strftime("%H:%M") %>
                      </div>
                    </div>
                  </div>
                </div>
                
                <% if order.order_items.any? %>
                  <div class="mt-3">
                    <div class="text-sm text-gray-600">
                      <% order.order_items.limit(3).each_with_index do |item, index| %>
                        <%= "#{item.quantity}x #{item.product_variant.display_name}" %>
                        <% unless index == order.order_items.limit(3).count - 1 %>
                          <span class="mx-1">•</span>
                        <% end %>
                      <% end %>
                      <% if order.order_items.count > 3 %>
                        <span class="text-gray-400">... y <%= order.order_items.count - 3 %> más</span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
                
                <% if order.shipping_city.present? %>
                  <div class="mt-2">
                    <div class="text-sm text-gray-500">
                      🚚 <%= order.shipping_city %>
                      <% if order.shipping_address.present? %>
                        • <%= order.shipping_address %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </li>
          <% end %>
        <% else %>
          <li class="px-4 py-8 text-center">
            <div class="text-gray-500">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No hay pedidos</h3>
              <p class="mt-1 text-sm text-gray-500">Comienza creando tu primer pedido.</p>
              <div class="mt-6">
                <%= link_to "Nuevo Pedido", new_order_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>