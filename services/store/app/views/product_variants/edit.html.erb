<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center gap-3">
      <%= link_to [@product, @variant], class: "text-gray-400 hover:text-gray-600" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      <% end %>
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Edit Variant</h1>
        <p class="text-sm text-gray-500 mt-1">Update variant information and settings</p>
      </div>
    </div>
  </div>

  <!-- Form -->
  <%= render 'form', product: @product, variant: @variant %>

  <!-- Danger Zone -->
  <div class="mt-8 bg-red-50 border border-red-200 rounded-lg p-6">
    <h3 class="text-lg font-medium text-red-900 mb-2">Danger Zone</h3>
    <p class="text-sm text-red-700 mb-4">
      Once you delete a variant, there is no going back. Please be certain.
    </p>
    <%= link_to 'Delete Variant', [@product, @variant], 
        method: :delete,
        data: { 
          confirm: 'Are you sure? This action cannot be undone.',
          turbo_method: :delete
        },
        class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700" %>
  </div>
</div>