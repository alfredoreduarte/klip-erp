<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <%= link_to @product, class: "text-gray-400 hover:text-gray-600" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        <% end %>
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Product Variants</h1>
          <p class="text-sm text-gray-500 mt-1"><%= @product.name %> variants management</p>
        </div>
      </div>
      
      <div class="flex gap-3">
        <%= link_to new_product_variant_path(@product), 
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Add Variant
        <% end %>
      </div>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow p-4">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-blue-100 rounded-md flex items-center justify-center">
            <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-gray-500">Total Variants</p>
          <p class="text-lg font-semibold text-gray-900"><%= @variants.count %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-green-100 rounded-md flex items-center justify-center">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-gray-500">Active Variants</p>
          <p class="text-lg font-semibold text-gray-900"><%= @active_variants %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-purple-100 rounded-md flex items-center justify-center">
            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
          </div>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-gray-500">Total Inventory</p>
          <p class="text-lg font-semibold text-gray-900"><%= @total_inventory %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-4">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-yellow-100 rounded-md flex items-center justify-center">
            <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-gray-500">Total Value</p>
          <p class="text-lg font-semibold text-gray-900">₲<%= number_with_delimiter(@total_value.to_i) %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Variants Table -->
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <% if @variants.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Variant</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">SKU</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pricing</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Inventory</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @variants.each do |variant| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <% if variant.image.attached? %>
                    <%= image_tag variant.image, class: "w-12 h-12 object-cover rounded mr-3 border" %>
                  <% elsif @product.image.attached? %>
                    <%= image_tag @product.image, class: "w-12 h-12 object-cover rounded mr-3 border opacity-50" %>
                  <% else %>
                    <div class="w-12 h-12 bg-gray-100 rounded mr-3 flex items-center justify-center border">
                      <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                    </div>
                  <% end %>
                  <div>
                    <div class="text-sm font-medium text-gray-900">
                      <%= link_to variant.name.presence || "Default Variant", product_variant_path(@product, variant), class: "hover:text-blue-600" %>
                    </div>
                    <% if variant.option_values.any? %>
                      <div class="text-xs text-gray-500 mt-1">
                        <%= variant.option_values.map { |k, v| "#{k.capitalize}: #{v}" }.join(' • ') %>
                      </div>
                    <% end %>
                    <div class="text-xs text-gray-400 mt-1">Position: <%= variant.position %></div>
                  </div>
                </div>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900"><%= variant.sku %></div>
                <% if variant.barcode.present? %>
                  <div class="text-xs text-gray-500">Barcode: <%= variant.barcode %></div>
                <% end %>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">₲<%= number_with_delimiter(variant.price) %></div>
                <% if variant.cost_price %>
                  <div class="text-xs text-gray-500">Cost: ₲<%= number_with_delimiter(variant.cost_price) %></div>
                <% end %>
                <% if variant.compare_at_price && variant.compare_at_price > variant.price %>
                  <div class="text-xs text-gray-400 line-through">₲<%= number_with_delimiter(variant.compare_at_price) %></div>
                <% end %>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <span class="text-sm font-medium <%= variant.low_stock? ? 'text-red-600' : 'text-gray-900' %>">
                    <%= variant.inventory_quantity %> units
                  </span>
                  <% if variant.low_stock? %>
                    <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      Low Stock
                    </span>
                  <% elsif variant.out_of_stock? %>
                    <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      Out of Stock
                    </span>
                  <% end %>
                </div>
                <% if variant.track_inventory? %>
                  <div class="text-xs text-gray-500 mt-1">
                    Policy: <%= variant.inventory_policy.capitalize %>
                  </div>
                <% else %>
                  <div class="text-xs text-gray-500 mt-1">Not tracked</div>
                <% end %>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= variant.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= variant.active? ? 'Active' : 'Inactive' %>
                </span>
                <% unless variant.requires_shipping? %>
                  <div class="text-xs text-gray-500 mt-1">Digital</div>
                <% end %>
              </td>
              
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <div class="flex flex-col gap-1">
                  <div class="flex gap-2">
                    <%= link_to 'View', product_variant_path(@product, variant), class: "text-blue-600 hover:text-blue-900" %>
                    <%= link_to 'Edit', edit_product_variant_path(@product, variant), class: "text-gray-600 hover:text-gray-900" %>
                  </div>
                  <div class="flex gap-2">
                    <% if variant.active? %>
                      <%= link_to 'Deactivate', deactivate_product_variant_path(@product, variant), 
                          data: { 
                            turbo_method: :post,
                            confirm: "Deactivate this variant? It will no longer be available for purchase." 
                          },
                          class: "text-red-600 hover:text-red-900 text-xs" %>
                    <% else %>
                      <%= link_to 'Activate', activate_product_variant_path(@product, variant), 
                          data: { 
                            turbo_method: :post,
                            confirm: "Activate this variant?" 
                          },
                          class: "text-green-600 hover:text-green-900 text-xs" %>
                    <% end %>
                    <%= link_to 'Duplicate', duplicate_product_variant_path(@product, variant), 
                        data: { turbo_method: :post }, 
                        class: "text-purple-600 hover:text-purple-900 text-xs" %>
                  </div>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No variants created</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by creating your first product variant.</p>
        <div class="mt-6">
          <%= link_to new_product_variant_path(@product), 
              class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Add First Variant
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>