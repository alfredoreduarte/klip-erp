<%= form_with model: [product, variant], local: true, multipart: true, class: "space-y-6" do |form| %>
  <% if variant.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% variant.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Basic Information</h3>
      <p class="mt-1 text-sm text-gray-500">Essential variant details and identification.</p>
    </div>
    
    <div class="px-6 py-4 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :sku, "SKU (Stock Keeping Unit)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :sku, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "Enter unique SKU" %>
          <p class="mt-1 text-sm text-gray-500">Must be unique across all variants</p>
        </div>
        
        <div>
          <%= form.label :barcode, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :barcode, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "Barcode (optional)" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :name, "Variant Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :name, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "e.g., Red Large, Size M" %>
          <p class="mt-1 text-sm text-gray-500">Optional: Leave blank for default variant</p>
        </div>
        
        <div>
          <%= form.label :position, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.number_field :position, min: 1,
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "Display order" %>
        </div>
      </div>

      <div>
        <%= form.label :image, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.file_field :image, 
            accept: "image/*",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="mt-1 text-sm text-gray-500">Upload variant-specific image (optional)</p>
        <% if variant.image.attached? %>
          <div class="mt-2">
            <%= image_tag variant.image, class: "w-20 h-20 object-cover rounded-md border" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Pricing</h3>
      <p class="mt-1 text-sm text-gray-500">Set variant-specific pricing information.</p>
    </div>
    
    <div class="px-6 py-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <%= form.label :price, "Selling Price", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <span class="text-gray-500 sm:text-sm">₲</span>
            </div>
            <%= form.number_field :price, step: 0.01, min: 0,
                class: "w-full pl-7 pr-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "0.00" %>
          </div>
        </div>
        
        <div>
          <%= form.label :cost_price, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <span class="text-gray-500 sm:text-sm">₲</span>
            </div>
            <%= form.number_field :cost_price, step: 0.01, min: 0,
                class: "w-full pl-7 pr-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "0.00" %>
          </div>
          <p class="mt-1 text-sm text-gray-500">Cost for profit tracking</p>
        </div>
        
        <div>
          <%= form.label :compare_at_price, "Compare At Price", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <span class="text-gray-500 sm:text-sm">₲</span>
            </div>
            <%= form.number_field :compare_at_price, step: 0.01, min: 0,
                class: "w-full pl-7 pr-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "0.00" %>
          </div>
          <p class="mt-1 text-sm text-gray-500">Original price for discounts</p>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Inventory & Shipping</h3>
      <p class="mt-1 text-sm text-gray-500">Configure inventory tracking and shipping settings.</p>
    </div>
    
    <div class="px-6 py-4 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :inventory_quantity, "Initial Inventory", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.number_field :inventory_quantity, min: 0,
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "0" %>
          <p class="mt-1 text-sm text-gray-500">Starting inventory quantity</p>
        </div>
        
        <div>
          <%= form.label :inventory_policy, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.select :inventory_policy, 
              options_for_select([
                ['Deny (Stop selling when out of stock)', 'deny'],
                ['Continue (Allow backorders)', 'continue']
              ], variant.inventory_policy || 'deny'),
              {}, { class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" } %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :weight, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="flex gap-2">
            <%= form.number_field :weight, step: 0.01, min: 0,
                class: "flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "0.00" %>
            <%= form.select :weight_unit, 
                options_for_select([
                  ['kg', 'kg'],
                  ['g', 'g'],
                  ['lb', 'lb'],
                  ['oz', 'oz']
                ], variant.weight_unit || 'kg'),
                {}, { class: "px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" } %>
          </div>
        </div>
        
        <div>
          <%= form.label :fulfillment_service, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.select :fulfillment_service, 
              options_for_select([
                ['Manual', 'manual'],
                ['Automatic', 'automatic']
              ], variant.fulfillment_service || 'manual'),
              {}, { class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" } %>
        </div>
      </div>

      <!-- Checkboxes -->
      <div class="space-y-4">
        <div class="flex items-center">
          <%= form.check_box :active, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
          <%= form.label :active, "Active variant", class: "ml-2 block text-sm text-gray-900" %>
        </div>
        
        <div class="flex items-center">
          <%= form.check_box :track_inventory, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
          <%= form.label :track_inventory, "Track inventory for this variant", class: "ml-2 block text-sm text-gray-900" %>
        </div>
        
        <div class="flex items-center">
          <%= form.check_box :requires_shipping, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
          <%= form.label :requires_shipping, "This variant requires shipping", class: "ml-2 block text-sm text-gray-900" %>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Variant Options</h3>
      <p class="mt-1 text-sm text-gray-500">Define variant-specific attributes like size, color, material, etc.</p>
    </div>
    
    <div class="px-6 py-4">
      <div id="variant-options">
        <% if variant.option_values.any? %>
          <% variant.option_values.each_with_index do |(key, value), index| %>
            <div class="flex gap-4 mb-4 variant-option">
              <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">Option Name</label>
                <input type="text" name="product_variant[option_values][<%= key %>]" value="<%= key %>" 
                       class="option-key w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="e.g., Size, Color, Material" readonly>
              </div>
              <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">Option Value</label>
                <input type="text" name="product_variant[option_values][<%= key %>]" value="<%= value %>" 
                       class="option-value w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="e.g., Large, Red, Cotton">
              </div>
              <div class="flex items-end">
                <button type="button" class="remove-option px-3 py-2 text-red-600 hover:text-red-800">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                </button>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="flex gap-4 mb-4 variant-option">
            <div class="flex-1">
              <label class="block text-sm font-medium text-gray-700 mb-1">Option Name</label>
              <input type="text" class="option-key w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
                     placeholder="e.g., Size, Color, Material">
            </div>
            <div class="flex-1">
              <label class="block text-sm font-medium text-gray-700 mb-1">Option Value</label>
              <input type="text" class="option-value w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
                     placeholder="e.g., Large, Red, Cotton">
            </div>
            <div class="flex items-end">
              <button type="button" class="remove-option px-3 py-2 text-red-600 hover:text-red-800">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
              </button>
            </div>
          </div>
        <% end %>
      </div>
      
      <button type="button" id="add-option" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Add Option
      </button>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="flex justify-end gap-3 pt-6 border-t border-gray-200">
    <%= link_to 'Cancel', variant.persisted? ? [product, variant] : [product, :variants], 
        class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
    <%= form.submit variant.persisted? ? 'Update Variant' : 'Create Variant',
        class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700" %>
  </div>
<% end %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const variantOptions = document.getElementById('variant-options');
  const addOptionBtn = document.getElementById('add-option');
  
  // Add new option row
  addOptionBtn.addEventListener('click', function() {
    const optionDiv = document.createElement('div');
    optionDiv.className = 'flex gap-4 mb-4 variant-option';
    optionDiv.innerHTML = `
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">Option Name</label>
        <input type="text" class="option-key w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
               placeholder="e.g., Size, Color, Material">
      </div>
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">Option Value</label>
        <input type="text" class="option-value w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
               placeholder="e.g., Large, Red, Cotton">
      </div>
      <div class="flex items-end">
        <button type="button" class="remove-option px-3 py-2 text-red-600 hover:text-red-800">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
        </button>
      </div>
    `;
    variantOptions.appendChild(optionDiv);
  });
  
  // Remove option row
  variantOptions.addEventListener('click', function(e) {
    if (e.target.closest('.remove-option')) {
      e.target.closest('.variant-option').remove();
    }
  });
  
  // Update hidden field names when form is submitted
  document.querySelector('form').addEventListener('submit', function() {
    const options = {};
    document.querySelectorAll('.variant-option').forEach(function(option) {
      const key = option.querySelector('.option-key').value.trim();
      const value = option.querySelector('.option-value').value.trim();
      if (key && value) {
        options[key] = value;
      }
    });
    
    // Remove existing option_values hidden fields
    document.querySelectorAll('input[name*="option_values"]').forEach(function(input) {
      if (input.type === 'hidden') {
        input.remove();
      }
    });
    
    // Add new hidden fields
    Object.keys(options).forEach(function(key) {
      const hiddenInput = document.createElement('input');
      hiddenInput.type = 'hidden';
      hiddenInput.name = `product_variant[option_values][${key}]`;
      hiddenInput.value = options[key];
      document.querySelector('form').appendChild(hiddenInput);
    });
  });
});
</script>