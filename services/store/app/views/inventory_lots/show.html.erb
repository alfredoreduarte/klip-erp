<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <%= link_to inventory_lots_path, class: "text-gray-400 hover:text-gray-600" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        <% end %>
        <div>
          <h1 class="text-2xl font-bold text-gray-900">
            Inventory Lot <%= @lot.lot_number %>
          </h1>
          <p class="text-sm text-gray-500 mt-1">Detailed lot information and tracking</p>
        </div>
      </div>
      
      <div class="flex gap-2">
        <%= link_to edit_inventory_lot_path(@lot), 
            class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
          Edit Lot
        <% end %>
        
        <% if @lot.active? && @lot.quantity_remaining > 0 %>
          <%= link_to new_inventory_adjustment_path(product_variant_id: @lot.product_variant_id, lot_id: @lot.id), 
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"></path>
            </svg>
            Adjust Stock
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Lot Status -->
      <div class="bg-white shadow rounded-lg p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-medium text-gray-900">Lot Status</h3>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
            <%= case @lot.status
                when 'active' then 'bg-green-100 text-green-800'
                when 'depleted' then 'bg-gray-100 text-gray-800'
                when 'expired' then 'bg-red-100 text-red-800'
                else 'bg-gray-100 text-gray-800'
                end %>">
            <%= @lot.status.capitalize %>
          </span>
        </div>
        
        <div class="grid grid-cols-2 gap-6">
          <div>
            <div class="text-2xl font-bold text-gray-900">
              <%= @lot.quantity_remaining %>
            </div>
            <div class="text-sm text-gray-500">Units Remaining</div>
            <div class="w-full bg-gray-200 rounded-full h-2 mt-2">
              <div class="bg-blue-600 h-2 rounded-full" 
                   style="width: <%= @lot.quantity_received > 0 ? (@lot.quantity_remaining.to_f / @lot.quantity_received * 100) : 0 %>%"></div>
            </div>
            <div class="text-xs text-gray-500 mt-1">
              <%= number_to_percentage(@lot.quantity_received > 0 ? (@lot.quantity_remaining.to_f / @lot.quantity_received * 100) : 0, precision: 0) %> remaining
            </div>
          </div>
          
          <div>
            <div class="text-2xl font-bold text-gray-900">
              <%= @lot.quantity_received %>
            </div>
            <div class="text-sm text-gray-500">Units Received</div>
            <% if @lot.expiry_date && @lot.active? %>
              <div class="mt-2">
                <div class="text-sm <%= @lot.expiry_date <= 30.days.from_now ? 'text-orange-600' : 'text-gray-500' %>">
                  <% if @lot.expiry_date <= Date.current %>
                    ⚠️ Expired <%= time_ago_in_words(@lot.expiry_date) %> ago
                  <% elsif @lot.expiry_date <= 30.days.from_now %>
                    ⏰ Expires in <%= time_ago_in_words(@lot.expiry_date) %>
                  <% else %>
                    📅 Expires <%= @lot.expiry_date.strftime('%m/%d/%Y') %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Product Information -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Product Information</h3>
        </div>
        
        <div class="px-6 py-4">
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0">
              <% if @lot.product_variant.image.attached? %>
                <%= image_tag @lot.product_variant.image, class: "w-20 h-20 object-cover rounded-lg" %>
              <% elsif @product.image.attached? %>
                <%= image_tag @product.image, class: "w-20 h-20 object-cover rounded-lg opacity-75" %>
              <% else %>
                <div class="w-20 h-20 bg-gray-100 rounded-lg flex items-center justify-center">
                  <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                  </svg>
                </div>
              <% end %>
            </div>
            
            <div class="flex-1">
              <h4 class="text-lg font-medium text-gray-900">
                <%= link_to @product.name, @product, class: "hover:text-blue-600" %>
              </h4>
              <dl class="mt-2 grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                  <dt class="text-sm font-medium text-gray-500">SKU</dt>
                  <dd class="mt-1 text-sm text-gray-900 font-mono"><%= @product_variant.sku %></dd>
                </div>
                
                <% if @product_variant.barcode.present? %>
                  <div>
                    <dt class="text-sm font-medium text-gray-500">Barcode</dt>
                    <dd class="mt-1 text-sm text-gray-900 font-mono"><%= @product_variant.barcode %></dd>
                  </div>
                <% end %>
                
                <% if @product.category.present? %>
                  <div>
                    <dt class="text-sm font-medium text-gray-500">Category</dt>
                    <dd class="mt-1 text-sm text-gray-900"><%= @product.category %></dd>
                  </div>
                <% end %>
                
                <div>
                  <dt class="text-sm font-medium text-gray-500">Status</dt>
                  <dd class="mt-1 text-sm text-gray-900">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Active
                    </span>
                  </dd>
                </div>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Cost Information -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Cost Breakdown</h3>
        </div>
        
        <div class="px-6 py-4">
          <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div>
              <dt class="text-sm font-medium text-gray-500">Unit Cost</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <% if @lot.unit_cost %>
                  ₲<%= number_with_delimiter(@lot.unit_cost) %>
                <% else %>
                  <span class="text-gray-400">Not specified</span>
                <% end %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Total Cost</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <% if @lot.total_cost %>
                  ₲<%= number_with_delimiter(@lot.total_cost) %>
                <% else %>
                  <span class="text-gray-400">Not calculated</span>
                <% end %>
              </dd>
            </div>
            
            <% if @lot.landed_cost_per_unit && @lot.landed_cost_per_unit != @lot.unit_cost %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Landed Cost Per Unit</dt>
                <dd class="mt-1 text-sm text-gray-900">
                  ₲<%= number_with_delimiter(@lot.landed_cost_per_unit) %>
                </dd>
              </div>
              
              <div>
                <dt class="text-sm font-medium text-gray-500">Total Landed Cost</dt>
                <dd class="mt-1 text-sm text-gray-900">
                  <% if @lot.total_landed_cost %>
                    ₲<%= number_with_delimiter(@lot.total_landed_cost) %>
                  <% else %>
                    ₲<%= number_with_delimiter(@lot.landed_cost_per_unit * @lot.quantity_received) %>
                  <% end %>
                </dd>
              </div>
            <% end %>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Remaining Value</dt>
              <dd class="mt-1 text-sm font-medium text-gray-900">
                <% unit_cost = @lot.landed_cost_per_unit || @lot.unit_cost %>
                <% if unit_cost %>
                  ₲<%= number_with_delimiter(unit_cost * @lot.quantity_remaining) %>
                <% else %>
                  <span class="text-gray-400">Cannot calculate</span>
                <% end %>
              </dd>
            </div>
          </dl>
        </div>
      </div>

      <!-- Supplier Information -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Supplier & Purchase Details</h3>
        </div>
        
        <div class="px-6 py-4">
          <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div>
              <dt class="text-sm font-medium text-gray-500">Supplier</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <%= @lot.supplier_name.presence || "Not specified" %>
              </dd>
            </div>
            
            <% if @lot.purchase_order_number.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Purchase Order</dt>
                <dd class="mt-1 text-sm text-gray-900 font-mono">
                  <%= @lot.purchase_order_number %>
                </dd>
              </div>
            <% end %>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Received Date</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <% if @lot.received_date %>
                  <%= @lot.received_date.strftime('%B %d, %Y') %>
                  <span class="text-gray-500">(<%= time_ago_in_words(@lot.received_date) %> ago)</span>
                <% else %>
                  <span class="text-gray-400">Not specified</span>
                <% end %>
              </dd>
            </div>
            
            <% if @lot.expiry_date %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Expiry Date</dt>
                <dd class="mt-1 text-sm text-gray-900">
                  <%= @lot.expiry_date.strftime('%B %d, %Y') %>
                  <% if @lot.expiry_date <= Date.current %>
                    <span class="text-red-600">(Expired)</span>
                  <% elsif @lot.expiry_date <= 30.days.from_now %>
                    <span class="text-orange-600">(Expires Soon)</span>
                  <% end %>
                </dd>
              </div>
            <% end %>
          </dl>
        </div>
      </div>

      <!-- Related Inventory Lots -->
      <% if @related_lots.any? %>
        <div class="bg-white shadow rounded-lg">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">Other Lots for This Product</h3>
          </div>
          
          <div class="overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Lot</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Quantity</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Received</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @related_lots.each do |lot| %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                      <%= link_to lot.lot_number, lot, class: "text-blue-600 hover:text-blue-800" %>
                    </td>
                    
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                        <%= case lot.status
                            when 'active' then 'bg-green-100 text-green-800'
                            when 'depleted' then 'bg-gray-100 text-gray-800'
                            when 'expired' then 'bg-red-100 text-red-800'
                            else 'bg-gray-100 text-gray-800'
                            end %>">
                        <%= lot.status.capitalize %>
                      </span>
                    </td>
                    
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                      <%= lot.quantity_remaining %> / <%= lot.quantity_received %>
                    </td>
                    
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= lot.received_date&.strftime('%m/%d/%Y') || 'N/A' %>
                    </td>
                    
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                      <%= link_to 'View', lot, class: "text-blue-600 hover:text-blue-900" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Quick Stats -->
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Quick Stats</h3>
        
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Lot Number:</span>
              <span class="text-gray-900 font-medium"><%= @lot.lot_number %></span>
            </div>
          </div>
          
          <div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">FIFO Priority:</span>
              <span class="text-gray-900 font-medium">
                <%= @lot.received_date&.strftime('%Y-%m-%d') || 'N/A' %>
              </span>
            </div>
          </div>
          
          <div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Utilization:</span>
              <span class="text-gray-900 font-medium">
                <%= number_to_percentage(@lot.quantity_received > 0 ? ((@lot.quantity_received - @lot.quantity_remaining).to_f / @lot.quantity_received * 100) : 0, precision: 0) %>
              </span>
            </div>
          </div>
          
          <% if @lot.unit_cost %>
            <div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">Value per Unit:</span>
                <span class="text-gray-900 font-medium">₲<%= number_with_delimiter(@lot.landed_cost_per_unit || @lot.unit_cost) %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Quick Actions</h3>
        
        <div class="space-y-3">
          <%= link_to inventory_lots_path, 
              class: "w-full flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
            All Lots
          <% end %>
          
          <%= link_to @product, 
              class: "w-full flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
            View Product
          <% end %>
          
          <% if @lot.active? %>
            <%= link_to new_inventory_adjustment_path(product_variant_id: @lot.product_variant_id, lot_id: @lot.id), 
                class: "w-full flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
              <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"></path>
              </svg>
              Create Adjustment
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Alerts -->
      <% if @lot.expiry_date && @lot.expiry_date <= 30.days.from_now && @lot.active? %>
        <div class="bg-orange-50 border border-orange-200 rounded-lg p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L5.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-orange-800">
                <% if @lot.expiry_date <= Date.current %>
                  Lot Expired
                <% else %>
                  Expiring Soon
                <% end %>
              </h3>
              <div class="mt-2 text-sm text-orange-700">
                <p>
                  <% if @lot.expiry_date <= Date.current %>
                    This lot expired <%= time_ago_in_words(@lot.expiry_date) %> ago. Consider adjusting to expired status.
                  <% else %>
                    This lot expires in <%= time_ago_in_words(@lot.expiry_date) %>. Plan to use soon.
                  <% end %>
                </p>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <% if @lot.quantity_remaining == 0 && @lot.status == 'active' %>
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-gray-800">Lot Depleted</h3>
              <div class="mt-2 text-sm text-gray-600">
                <p>This lot has no remaining inventory. Consider marking as depleted.</p>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>