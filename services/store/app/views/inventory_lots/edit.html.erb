<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center gap-3">
      <%= link_to @lot, class: "text-gray-400 hover:text-gray-600" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      <% end %>
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Edit Inventory Lot <%= @lot.lot_number %></h1>
        <p class="text-sm text-gray-500 mt-1">Update inventory lot details and tracking information</p>
      </div>
    </div>
  </div>

  <!-- Current Product Info -->
  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
    <div class="flex items-start space-x-3">
      <% if @lot.product_variant.image.attached? %>
        <%= image_tag @lot.product_variant.image, class: "w-12 h-12 object-cover rounded-lg" %>
      <% elsif @lot.product_variant.product.image.attached? %>
        <%= image_tag @lot.product_variant.product.image, class: "w-12 h-12 object-cover rounded-lg opacity-75" %>
      <% else %>
        <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
          </svg>
        </div>
      <% end %>
      
      <div class="flex-1">
        <h3 class="text-sm font-medium text-blue-900">Current Product</h3>
        <p class="text-sm text-blue-700">
          <%= @lot.product_variant.product.name %> - <%= @lot.product_variant.sku %>
        </p>
        <p class="text-xs text-blue-600">
          Current: <%= @lot.quantity_remaining %>/<%= @lot.quantity_received %> units remaining
        </p>
      </div>
    </div>
  </div>

  <!-- Form -->
  <div class="bg-white shadow rounded-lg">
    <%= form_with model: @lot, class: "space-y-6" do |form| %>
      <% if @lot.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L5.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">Please correct the following errors:</h3>
              <div class="mt-2 text-sm text-red-700">
                <ul class="list-disc list-inside">
                  <% @lot.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <div class="px-6 py-6 space-y-6">
        <!-- Product Selection -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Product</label>
            <%= form.select :product_variant_id, 
                options_from_collection_for_select(
                  @products.map { |p| p.product_variants.map { |pv| [pv, "#{p.name} - #{pv.sku}", pv.id] } }.flatten(1),
                  :third, :second, @lot.product_variant_id
                ),
                { prompt: 'Select a product variant...' },
                { 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
                } %>
            <p class="mt-1 text-xs text-gray-500">⚠️ Changing product will affect inventory tracking</p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Lot Number</label>
            <div class="px-3 py-2 bg-gray-50 border border-gray-300 rounded-md">
              <div class="text-sm text-gray-900 font-mono"><%= @lot.lot_number %></div>
            </div>
            <p class="mt-1 text-xs text-gray-500">Lot number is automatically generated</p>
          </div>
        </div>

        <!-- Quantity Information -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div>
            <label for="quantity_received" class="block text-sm font-medium text-gray-700 mb-2">
              Quantity Received <span class="text-red-500">*</span>
            </label>
            <%= form.number_field :quantity_received, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                min: 1,
                step: 1,
                required: true,
                data: {
                  controller: "quantity-calculator",
                  action: "input->quantity-calculator#calculate"
                } %>
            <p class="mt-1 text-xs text-orange-600">⚠️ Changing this affects all calculations</p>
          </div>
          
          <div>
            <label for="quantity_remaining" class="block text-sm font-medium text-gray-700 mb-2">
              Quantity Remaining <span class="text-red-500">*</span>
            </label>
            <%= form.number_field :quantity_remaining, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                min: 0,
                step: 1,
                required: true,
                data: {
                  target: "quantity-calculator.remaining"
                } %>
            <p class="mt-1 text-xs text-gray-500">Cannot exceed quantity received</p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
            <%= form.select :status,
                options_for_select([
                  ['Active', 'active'],
                  ['Depleted', 'depleted'],
                  ['Expired', 'expired']
                ], @lot.status),
                {},
                { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" } %>
            <p class="mt-1 text-xs text-gray-500">Current lot status</p>
          </div>
        </div>

        <!-- Usage Summary -->
        <% if @lot.quantity_received > @lot.quantity_remaining %>
          <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
            <h4 class="text-sm font-medium text-gray-900 mb-2">Usage Summary</h4>
            <div class="grid grid-cols-3 gap-4 text-sm">
              <div>
                <span class="text-gray-500">Units Used:</span>
                <span class="ml-1 font-medium text-gray-900">
                  <%= @lot.quantity_received - @lot.quantity_remaining %>
                </span>
              </div>
              <div>
                <span class="text-gray-500">Utilization:</span>
                <span class="ml-1 font-medium text-gray-900">
                  <%= number_to_percentage((@lot.quantity_received - @lot.quantity_remaining).to_f / @lot.quantity_received * 100, precision: 0) %>
                </span>
              </div>
              <div>
                <span class="text-gray-500">Value Consumed:</span>
                <span class="ml-1 font-medium text-gray-900">
                  <% if @lot.unit_cost %>
                    ₲<%= number_with_delimiter((@lot.quantity_received - @lot.quantity_remaining) * @lot.unit_cost) %>
                  <% else %>
                    N/A
                  <% end %>
                </span>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Cost Information -->
        <div class="border-t border-gray-200 pt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Cost Information</h3>
          
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div>
              <label for="unit_cost" class="block text-sm font-medium text-gray-700 mb-2">
                Unit Cost (₲)
              </label>
              <%= form.number_field :unit_cost, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                  step: 0.01,
                  min: 0,
                  data: {
                    target: "quantity-calculator.unitCost",
                    action: "input->quantity-calculator#calculate"
                  } %>
              <p class="mt-1 text-xs text-gray-500">Cost per unit</p>
            </div>
            
            <div>
              <label for="total_cost" class="block text-sm font-medium text-gray-700 mb-2">
                Total Cost (₲)
              </label>
              <%= form.number_field :total_cost, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                  step: 0.01,
                  min: 0,
                  data: {
                    target: "quantity-calculator.totalCost"
                  } %>
              <p class="mt-1 text-xs text-gray-500">Quantity × Unit Cost</p>
            </div>
            
            <div>
              <label for="landed_cost_per_unit" class="block text-sm font-medium text-gray-700 mb-2">
                Landed Cost per Unit (₲)
              </label>
              <%= form.number_field :landed_cost_per_unit, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                  step: 0.01,
                  min: 0 %>
              <p class="mt-1 text-xs text-gray-500">Including shipping, taxes, etc.</p>
            </div>
          </div>
        </div>

        <!-- Supplier & Purchase Information -->
        <div class="border-t border-gray-200 pt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Supplier & Purchase Details</h3>
          
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div>
              <label for="supplier_name" class="block text-sm font-medium text-gray-700 mb-2">
                Supplier Name
              </label>
              <%= form.text_field :supplier_name, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                  placeholder: "Supplier or vendor name" %>
              <p class="mt-1 text-xs text-gray-500">Name of the supplier or vendor</p>
            </div>
            
            <div>
              <label for="purchase_order_number" class="block text-sm font-medium text-gray-700 mb-2">
                Purchase Order Number
              </label>
              <%= form.text_field :purchase_order_number, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                  placeholder: "PO-2024-001" %>
              <p class="mt-1 text-xs text-gray-500">Reference number for purchase order</p>
            </div>
            
            <div>
              <label for="received_date" class="block text-sm font-medium text-gray-700 mb-2">
                Received Date <span class="text-red-500">*</span>
              </label>
              <%= form.date_field :received_date, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                  required: true %>
              <p class="mt-1 text-xs text-orange-600">⚠️ Changing affects FIFO ordering</p>
            </div>
            
            <div>
              <label for="expiry_date" class="block text-sm font-medium text-gray-700 mb-2">
                Expiry Date
              </label>
              <%= form.date_field :expiry_date, 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
              <p class="mt-1 text-xs text-gray-500">Best before or expiration date</p>
              
              <% if @lot.expiry_date && @lot.expiry_date <= 30.days.from_now %>
                <div class="mt-1 text-xs text-orange-600">
                  <% if @lot.expiry_date <= Date.current %>
                    ⚠️ This lot has expired
                  <% else %>
                    ⏰ This lot expires soon (<%= time_ago_in_words(@lot.expiry_date) %>)
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Additional Information -->
        <div class="border-t border-gray-200 pt-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Additional Information</h3>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Notes</label>
            <%= form.text_area :notes, 
                rows: 3,
                class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "Any additional notes about this lot" %>
            <p class="mt-1 text-xs text-gray-500">Notes about condition, quality, changes, etc.</p>
          </div>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex justify-between">
        <div>
          <% if @lot.quantity_remaining == 0 && @lot.status == 'active' %>
            <p class="text-sm text-orange-600">💡 Consider marking as 'Depleted' since no inventory remains</p>
          <% end %>
          
          <% if @lot.expiry_date && @lot.expiry_date <= Date.current && @lot.status == 'active' %>
            <p class="text-sm text-red-600">⚠️ Consider marking as 'Expired' since expiry date has passed</p>
          <% end %>
        </div>
        
        <div class="flex gap-3">
          <%= link_to 'Cancel', @lot, 
              class: "px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          
          <%= form.submit 'Update Inventory Lot', 
              class: "px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
        </div>
      </div>
    <% end %>
  </div>
  
  <!-- Danger Zone -->
  <% if @lot.quantity_remaining == 0 || @lot.status != 'active' %>
    <div class="mt-6 bg-white border border-red-200 shadow rounded-lg">
      <div class="px-6 py-4 border-b border-red-200 bg-red-50">
        <h3 class="text-lg font-medium text-red-900">Danger Zone</h3>
        <p class="text-sm text-red-700 mt-1">Irreversible and destructive actions</p>
      </div>
      
      <div class="px-6 py-4">
        <div class="flex items-center justify-between">
          <div>
            <h4 class="text-sm font-medium text-gray-900">Delete this inventory lot</h4>
            <p class="text-sm text-gray-500">
              Once deleted, this lot and all its tracking history will be permanently removed.
              <% if @lot.quantity_remaining > 0 %>
                <span class="text-red-600">This lot still has <%= @lot.quantity_remaining %> units remaining.</span>
              <% end %>
            </p>
          </div>
          
          <% if @lot.quantity_remaining == 0 %>
            <%= link_to @lot, method: :delete,
                class: "px-4 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50",
                data: { 
                  confirm: "Are you sure? This action cannot be undone.\n\nThis will permanently delete lot #{@lot.lot_number} and all its tracking history." 
                } do %>
              Delete Lot
            <% end %>
          <% else %>
            <button type="button" disabled
                class="px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-400 bg-gray-100 cursor-not-allowed">
              Cannot Delete
            </button>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Stimulus Controllers for Dynamic Behavior -->
<script>
  // Quantity Calculator Controller
  class QuantityCalculatorController extends Application.Controller {
    static targets = ["remaining", "unitCost", "totalCost"];
    
    calculate() {
      const quantityReceived = parseInt(this.element.value) || 0;
      const unitCost = parseFloat(this.unitCostTarget.value) || 0;
      
      // Calculate total cost
      if (unitCost > 0 && quantityReceived > 0) {
        this.totalCostTarget.value = (quantityReceived * unitCost).toFixed(2);
      }
      
      // Validate remaining quantity doesn't exceed received
      const remaining = parseInt(this.remainingTarget.value) || 0;
      if (remaining > quantityReceived) {
        this.remainingTarget.value = quantityReceived;
        alert('Quantity remaining cannot exceed quantity received');
      }
    }
  }

  // Register controller if Stimulus is available
  if (typeof Application !== 'undefined') {
    Application.register("quantity-calculator", QuantityCalculatorController);
  }
</script>