<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <%= link_to inventory_adjustments_path, class: "text-gray-400 hover:text-gray-600" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        <% end %>
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Inventory Adjustment</h1>
          <p class="text-sm text-gray-500 mt-1"><%= @adjustment.reference_number %></p>
        </div>
      </div>
      
      <div class="flex gap-2">
        <% unless @adjustment.approved? %>
          <%= link_to edit_inventory_adjustment_path(@adjustment), 
              class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Edit
          <% end %>
        <% end %>
        
        <% if @adjustment.requires_approval? && !@adjustment.approved? %>
          <button type="button" 
                  class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700"
                  onclick="approveAdjustment()">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Approve
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Adjustment Details -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Adjustment Details</h3>
        </div>
        
        <div class="px-6 py-4">
          <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <dt class="text-sm font-medium text-gray-500">Reference Number</dt>
              <dd class="mt-1 text-sm text-gray-900 font-mono"><%= @adjustment.reference_number %></dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Adjustment Type</dt>
              <dd class="mt-1">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= case @adjustment.adjustment_type
                      when 'purchase' then 'bg-green-100 text-green-800'
                      when 'sale' then 'bg-blue-100 text-blue-800'
                      when 'return' then 'bg-yellow-100 text-yellow-800'
                      when 'shrinkage', 'damage' then 'bg-red-100 text-red-800'
                      when 'count' then 'bg-purple-100 text-purple-800'
                      else 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= @adjustment.adjustment_type_name %>
                </span>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Quantity Change</dt>
              <dd class="mt-1 text-sm font-semibold <%= @adjustment.positive_adjustment? ? 'text-green-600' : 'text-red-600' %>">
                <%= @adjustment.positive_adjustment? ? '+' : '' %><%= @adjustment.quantity %> units
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Cost Impact</dt>
              <dd class="mt-1 text-sm font-medium text-gray-900">
                <% if @adjustment.cost_impact %>
                  ₲<%= number_with_delimiter(@adjustment.cost_impact.abs) %>
                <% else %>
                  <span class="text-gray-400">Not calculated</span>
                <% end %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Reason</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @adjustment.reason %></dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Date Created</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <%= @adjustment.created_at.strftime('%B %d, %Y at %I:%M %p') %>
              </dd>
            </div>
          </dl>
          
          <% if @adjustment.notes.present? %>
            <div class="mt-6">
              <dt class="text-sm font-medium text-gray-500">Additional Notes</dt>
              <dd class="mt-1 text-sm text-gray-900 bg-gray-50 rounded-md p-3">
                <%= simple_format(@adjustment.notes) %>
              </dd>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Product Information -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Product Information</h3>
        </div>
        
        <div class="px-6 py-4">
          <div class="flex items-start gap-4">
            <% if @product_variant.image.attached? %>
              <%= image_tag @product_variant.image, class: "w-20 h-20 object-cover rounded-lg border" %>
            <% elsif @product.image.attached? %>
              <%= image_tag @product.image, class: "w-20 h-20 object-cover rounded-lg border opacity-75" %>
            <% else %>
              <div class="w-20 h-20 bg-gray-100 rounded-lg border flex items-center justify-center">
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
              </div>
            <% end %>
            
            <div class="flex-1">
              <h4 class="text-lg font-medium text-gray-900">
                <%= link_to @product.name, @product, class: "hover:text-blue-600" %>
              </h4>
              <% if @product_variant.name.present? %>
                <p class="text-sm text-gray-600"><%= @product_variant.name %></p>
              <% end %>
              <p class="text-sm text-gray-500 mt-1">SKU: <%= @product_variant.sku %></p>
              <% if @product_variant.barcode.present? %>
                <p class="text-xs text-gray-400">Barcode: <%= @product_variant.barcode %></p>
              <% end %>
              
              <div class="mt-3 grid grid-cols-2 gap-4 text-sm">
                <div>
                  <span class="font-medium text-gray-500">Current Stock:</span>
                  <span class="text-gray-900"><%= @product_variant.inventory_quantity %> units</span>
                </div>
                <div>
                  <span class="font-medium text-gray-500">Current Price:</span>
                  <span class="text-gray-900">₲<%= number_with_delimiter(@product_variant.price) %></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Stock Impact -->
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Stock Impact</h3>
        </div>
        
        <div class="px-6 py-4">
          <div class="flex items-center justify-between py-3 border-b border-gray-100">
            <span class="text-sm font-medium text-gray-600">Stock Before:</span>
            <span class="text-sm text-gray-900"><%= @adjustment.quantity_before %> units</span>
          </div>
          
          <div class="flex items-center justify-between py-3 border-b border-gray-100">
            <span class="text-sm font-medium text-gray-600">Adjustment:</span>
            <span class="text-sm font-semibold <%= @adjustment.positive_adjustment? ? 'text-green-600' : 'text-red-600' %>">
              <%= @adjustment.positive_adjustment? ? '+' : '' %><%= @adjustment.quantity %> units
            </span>
          </div>
          
          <div class="flex items-center justify-between py-3 font-semibold">
            <span class="text-sm text-gray-900">Stock After:</span>
            <span class="text-sm text-gray-900"><%= @adjustment.quantity_after %> units</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Status Card -->
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Status</h3>
        
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-500">Approval Status:</span>
            <% if @adjustment.approved? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                Approved
              </span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                Pending
              </span>
            <% end %>
          </div>
          
          <% if @adjustment.approved? %>
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-gray-500">Approved At:</span>
              <span class="text-sm text-gray-900">
                <%= @adjustment.approved_at.strftime('%m/%d/%Y') if @adjustment.approved_at %>
              </span>
            </div>
          <% end %>
          
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-gray-500">Requires Approval:</span>
            <span class="text-sm text-gray-900">
              <%= @adjustment.requires_approval? ? 'Yes' : 'No' %>
            </span>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Actions</h3>
        
        <div class="space-y-3">
          <%= link_to [@product, :variants], 
              class: "w-full flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
            View All Variants
          <% end %>
          
          <%= link_to new_inventory_adjustment_path(product_variant_id: @product_variant.id), 
              class: "w-full flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            New Adjustment
          <% end %>
          
          <%= link_to inventory_adjustments_path(sku: @product_variant.sku), 
              class: "w-full flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
            </svg>
            View History
          <% end %>
        </div>
      </div>

      <!-- Metadata -->
      <% if @adjustment.metadata.any? %>
        <div class="bg-white shadow rounded-lg p-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Additional Data</h3>
          
          <dl class="space-y-2">
            <% @adjustment.metadata.each do |key, value| %>
              <div class="flex justify-between">
                <dt class="text-sm font-medium text-gray-500"><%= key.humanize %>:</dt>
                <dd class="text-sm text-gray-900"><%= value %></dd>
              </div>
            <% end %>
          </dl>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function approveAdjustment() {
  if (confirm('Are you sure you want to approve this adjustment? This action cannot be undone.')) {
    // Create a form and submit it
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '<%= inventory_adjustment_path(@adjustment) %>';
    
    const methodField = document.createElement('input');
    methodField.type = 'hidden';
    methodField.name = '_method';
    methodField.value = 'PATCH';
    
    const csrfField = document.createElement('input');
    csrfField.type = 'hidden';
    csrfField.name = 'authenticity_token';
    csrfField.value = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
    
    const approvedField = document.createElement('input');
    approvedField.type = 'hidden';
    approvedField.name = 'inventory_adjustment[approved]';
    approvedField.value = 'true';
    
    form.appendChild(methodField);
    form.appendChild(csrfField);
    form.appendChild(approvedField);
    
    document.body.appendChild(form);
    form.submit();
  }
}
</script>