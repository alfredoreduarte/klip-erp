# Production Environment Configuration
# Copy this file to .env.production and update with your actual values

# Domain Configuration
DOMAIN=your-domain.com

# Database Configuration
POSTGRES_PASSWORD=your_secure_database_password_here
POSTGRES_USER=postgres
POSTGRES_DB=store_production

# Rails Configuration
SECRET_KEY_BASE=your_secret_key_base_here_64_characters_minimum
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true

# WAHA (WhatsApp) Configuration
WAHA_BASE_URL=http://waha:3000
WAHA_WEBHOOK_URL=http://store:3000/waha/webhooks
WAHA_SESSION_NAME=production

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Backup Configuration
BACKUP_DIR=./backup
RETENTION_DAYS=30

# Compose Configuration
COMPOSE_FILE=docker-compose.prod.yml
IMAGE_TAG=latest

# SSL/TLS Configuration (for production)
LETSENCRYPT_EMAIL=admin@your-domain.com

# Optional: Additional Security
# RAILS_FORCE_SSL=true
# HSTS_ENABLED=true

# Optional: Email Configuration (for notifications)
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_DOMAIN=your-domain.com

# Optional: Monitoring
# SENTRY_DSN=https://your-sentry-dsn
# HONEYBADGER_API_KEY=your-honeybadger-key

# Optional: External Services
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name